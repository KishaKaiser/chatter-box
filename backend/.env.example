# Backend environment variables
# Copy this file to .env and fill in real values

# MySQL/MariaDB connection string (CloudPanel default)
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/chatter_box"

# Secret for signing JWT tokens – generate a long random string
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# Token expiry (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN="7d"

# Port the backend listens on (CloudPanel will reverse-proxy to this)
PORT=4000

# Comma-separated list of allowed frontend origins (no trailing slash)
# Examples: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN="http://localhost:5173"

# Set to "production" on the server
NODE_ENV="development"
